{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Preview Pages HTML",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/preview/preview-pages.ps1"
      ],
      "group": "build",
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Build Pages HTML Only",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/preview/preview-pages.ps1",
        "-NoServe"
      ],
      "group": "build",
      "isBackground": false,
      "problemMatcher": []
    }
  ]
}
