<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>Library</OutputType>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
	</PropertyGroup>

	<PropertyGroup>
		<PackageId>LVGLSharp.Core</PackageId>
		<Title>LVGLSharp Core Runtime Abstractions</Title>
		<Description>Shared LVGLSharp runtime abstractions and font helpers used by the Forms and platform runtime packages.</Description>
	</PropertyGroup>

	<ItemGroup>
	  <EmbeddedResource Include="Assets\Fonts\NotoSansSC-Regular.otf">
	    <LogicalName>LVGLSharp.Runtime.Linux.Assets.Fonts.NotoSansSC-Regular.otf</LogicalName>
	  </EmbeddedResource>
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="SixLabors.Fonts" Version="2.1.3" />
		<PackageReference Include="SixLabors.ImageSharp" Version="3.1.12" />
		<PackageReference Include="SixLabors.ImageSharp.Drawing" Version="2.1.7" />
	</ItemGroup>

 <ItemGroup>
	  <ProjectReference Include="..\LVGLSharp.Interop\LVGLSharp.Interop.csproj" />
	</ItemGroup>

	<ItemGroup>
		<None Include="..\LVGLSharp.Runtime.Linux\Assets\Fonts\NOTICE.txt" Pack="true" PackagePath="THIRD-PARTY-NOTICES\LVGLSharp.Core\" Visible="false" />
	</ItemGroup>

</Project>
