<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
	</PropertyGroup>

	<PropertyGroup>
		<PackageId>LVGLSharp.Interop</PackageId>
		<Title>LVGLSharp P/Invoke Bindings</Title>
		<Description>Auto-generated P/Invoke bindings for LVGL (via ClangSharpPInvokeGenerator). Provides low-level access to the full LVGL C API from .NET.</Description>
	</PropertyGroup>

	<!-- Non-Release builds consume the published native package. Pack keeps
	     the package dependency metadata for downstream NuGet consumers. -->
	<ItemGroup Condition="'$(Configuration)' != 'Release' Or '$(_IsPacking)' == 'true'">
		<PackageReference Include="LVGLSharp.Native" Version="$(LVGLSharpNativePackageVersion)" />
	</ItemGroup>

	<!-- Release and publish-oriented repo builds stay project-based so they
	     can use the native binaries generated from the current source tree. -->
	<ItemGroup Condition="'$(Configuration)' == 'Release' And '$(_IsPacking)' != 'true'">
		<ProjectReference Include="..\LVGLSharp.Native\LVGLSharp.Native.csproj" />
	</ItemGroup>

</Project>
