<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
	</PropertyGroup>

	<PropertyGroup>
		<PackageId>LVGLSharp.Interop</PackageId>
		<Title>LVGLSharp P/Invoke Bindings</Title>
		<Description>Auto-generated low-level P/Invoke bindings for LVGL, generated through ClangSharpPInvokeGenerator and intended for advanced integrations, custom hosts, and full C API access from .NET.</Description>
		<PackageTags>$(PackageTags);interop;pinvoke;bindings</PackageTags>
	</PropertyGroup>

	<!-- Pack keeps the package dependency metadata for downstream NuGet consumers.
	     Repository builds should prefer the local Native project whenever it exists,
	     so CI/demo builds do not require a pre-published LVGLSharp.Native package. -->
	<ItemGroup Condition="'$(_IsPacking)' == 'true' Or !Exists('..\LVGLSharp.Native\LVGLSharp.Native.csproj')">
		<PackageReference Include="LVGLSharp.Native" Version="$(LVGLSharpNativePackageVersion)" />
	</ItemGroup>

	<!-- Repository builds stay project-based so they can use the native binaries
	     generated from the current source tree, regardless of Debug/Release. -->
	<ItemGroup Condition="'$(_IsPacking)' != 'true' And Exists('..\LVGLSharp.Native\LVGLSharp.Native.csproj')">
		<ProjectReference Include="..\LVGLSharp.Native\LVGLSharp.Native.csproj" />
	</ItemGroup>

</Project>
